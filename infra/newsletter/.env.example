# Copy to .env on the server (do NOT commit .env). Generate strong values.
# Quick generation:  openssl rand -base64 32

# Database password (anything strong; only Listmonk and Postgres see it)
LISTMONK_DB_PASSWORD=replace-with-strong-random-string

# Admin login for Listmonk's web UI (https://newsletter.example.org/admin)
LISTMONK_ADMIN_USER=admin
LISTMONK_ADMIN_PASSWORD=replace-with-strong-random-string
